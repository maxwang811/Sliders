# ---------------------------------------------------------------------------
# Pick ONE provider. SLIDERS defaults to "azure".
# Set SLIDERS_LLM_PROVIDER=openai to use the public OpenAI API instead.
# ---------------------------------------------------------------------------
SLIDERS_LLM_PROVIDER=azure

# ---- Azure OpenAI ----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- OpenAI / OpenAI-compatible (used when SLIDERS_LLM_PROVIDER=openai) ----
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# For OpenRouter, use an sk-or- key and the base URL below. Bare model names
# (e.g. gpt-4.1) are auto-prefixed to the OpenRouter slug (openai/gpt-4.1).
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ---- Evaluator LLM (LLM-as-a-judge for benchmarks; optional) ----
EVAL_LLM_PROVIDER=
EVAL_AZURE_OPENAI_ENDPOINT=
EVAL_AZURE_OPENAI_API_KEY=

# ---- Run artifacts ----
SLIDERS_LOGS_DIR=./logs
SLIDERS_RESULTS=./results

# ---- Optional Redis cache for LLM responses. Leave unset to disable. ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Datadog Agent (LLM) Observability (optional) ----
# Required to send data to Datadog. Get one at:
# https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=
# Datadog site for your account (e.g. datadoghq.com, us3.datadoghq.com, datadoghq.eu).
DD_SITE=us3.datadoghq.com
DD_LLMOBS_ENABLED=true
DD_LLMOBS_AGENTLESS_ENABLED=true
DD_LLMOBS_ML_APP=sliders
